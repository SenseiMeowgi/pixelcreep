import { Theme } from "../theme.slint";

// 12x12 box, panel-bg fill / border border. When checked: accent fill + border,
// with a 4x4 page-bg inner dot. Label sits 8px to the right.
export component StyledCheckbox inherits Rectangle {
    in property <string> text;
    in-out property <bool> checked;
    callback toggled;

    height: 16px;
    horizontal-stretch: 1;
    background: transparent;

    touch := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled();
        }
    }

    HorizontalLayout {
        spacing: 8px;
        alignment: start;

        Rectangle {
            width: 12px;
            height: 12px;
            y: (parent.height - self.height) / 2;
            background: root.checked ? Theme.accent : Theme.panel-bg;
            border-width: 1px;
            border-color: root.checked ? Theme.accent : Theme.border;

            if root.checked : Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 4px;
                height: 4px;
                background: Theme.page-bg;
            }
        }

        Text {
            text: root.text;
            color: Theme.text-dim;
            font-size: 11.5px;
            vertical-alignment: center;
        }
    }
}
